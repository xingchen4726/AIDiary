.container {
  width: 100%;
  min-height: 100vh;
  padding: 34rpx 26rpx 120rpx;
  background: linear-gradient(180deg, #fbf8f2 0%, #f7f2ff 46%, #f2f6ff 100%);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: stretch;
}

.header {
  width: 100%;
  margin-bottom: 26rpx;
}

.title {
  display: block;
  font-size: 52rpx;
  font-weight: 700;
  color: #2b2434;
  line-height: 1.2;
  letter-spacing: 1rpx;
}

.subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #7d748b;
  line-height: 1.6;
}

.section-card {
  width: 100%;
  box-sizing: border-box;
  padding: 28rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(255, 255, 255, 0.7);
  box-shadow: 0 18rpx 44rpx rgba(60, 46, 90, 0.08);
  margin-bottom: 24rpx;
}

.user-card {
  padding: 32rpx;
  background: linear-gradient(140deg, #7160ff 0%, #9f7cff 55%, #b995ff 100%);
  border: none;
  box-shadow: 0 24rpx 48rpx rgba(96, 72, 178, 0.24);
}

.user-info {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  object-fit: cover;
  border: 4rpx solid rgba(255, 255, 255, 0.75);
}

.user-details {
  flex: 1;
}

.user-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.user-id {
  display: block;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.86);
  line-height: 1.4;
}

.stats-grid {
  display: flex;
  justify-content: space-around;
  gap: 20rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 18rpx;
  background: linear-gradient(160deg, #ffffff 0%, #fdfaff 100%);
  border: 1rpx solid #efe5ff;
}

.stat-number {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #6b55b5;
  margin-bottom: 8rpx;
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: #7d748b;
}

.section-head {
  margin-bottom: 20rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #312a3d;
}

.setting-list {
  display: flex;
  flex-direction: column;
  gap: 1rpx;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 20rpx;
  border-radius: 16rpx;
  border-bottom: none;
  background: linear-gradient(160deg, #ffffff 0%, #fdfaff 100%);
  border: 1rpx solid #efe5ff;
  margin-bottom: 12rpx;
}

.setting-item:last-child {
  margin-bottom: 0;
}

.setting-label {
  font-size: 26rpx;
  color: #3d3250;
}

.setting-arrow {
  font-size: 32rpx;
  color: #9a8faf;
  font-weight: 300;
}

.footer {
  margin-top: 40rpx;
  text-align: center;
  padding: 20rpx 0;
}

.footer-text {
  display: block;
  font-size: 22rpx;
  color: #7d748b;
  margin-bottom: 8rpx;
}

.footer-desc {
  display: block;
  font-size: 20rpx;
  color: #9a8faf;
  line-height: 1.4;
}
