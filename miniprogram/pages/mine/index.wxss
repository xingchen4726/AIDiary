.container {
  min-height: 100vh;
  padding: 32rpx 24rpx 120rpx;
  background: linear-gradient(180deg, #f4f8ff 0%, #f6f7fb 42%, #edf2ff 100%);
  box-sizing: border-box;
}

.header {
  margin-bottom: 28rpx;
}

.title {
  display: block;
  font-size: 52rpx;
  font-weight: 700;
  color: #1f2937;
  line-height: 1.2;
}

.subtitle {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #667085;
  line-height: 1.6;
}

.section-card {
  padding: 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 18rpx 40rpx rgba(15, 23, 42, 0.06);
  margin-bottom: 24rpx;
}

.user-card {
  padding: 32rpx;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  object-fit: cover;
  border: 4rpx solid #e0e7ff;
}

.user-details {
  flex: 1;
}

.user-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 8rpx;
}

.user-id {
  display: block;
  font-size: 20rpx;
  color: #98a2b3;
  line-height: 1.4;
}

.stats-grid {
  display: flex;
  justify-content: space-around;
  gap: 20rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 16rpx;
  background: #f8faff;
  border: 1rpx solid #e0e7ff;
}

.stat-number {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #4f7cff;
  margin-bottom: 8rpx;
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: #667085;
}

.section-head {
  margin-bottom: 20rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
}

.setting-list {
  display: flex;
  flex-direction: column;
  gap: 1rpx;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #edf2f7;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-label {
  font-size: 26rpx;
  color: #1f2937;
}

.setting-arrow {
  font-size: 32rpx;
  color: #98a2b3;
  font-weight: 300;
}

.footer {
  margin-top: 40rpx;
  text-align: center;
  padding: 20rpx 0;
}

.footer-text {
  display: block;
  font-size: 22rpx;
  color: #667085;
  margin-bottom: 8rpx;
}

.footer-desc {
  display: block;
  font-size: 20rpx;
  color: #98a2b3;
  line-height: 1.4;
}