<view class="container">
  <view class="header">
    <text class="title">AI 流水账</text>
    <text class="subtitle">支持 AI 智能总结</text>
  </view>

  <view class="hero-card">
    <view class="hero-badge">随时记录灵感与日常</view>
    <text class="hero-title">想到什么，就立刻记下来</text>
    <text class="hero-desc">通过文字速记，快速记录下当下的想法、待办事项和心情。</text>
  </view>

  <view class="inspiration-card section-card">
    <view class="section-head">
      <view>
        <text class="section-title">今日灵感</text>
        <text class="section-desc">{{inspirationMonthDay}} 的历史片段</text>
      </view>
      <view class="inspiration-refresh" bindtap="refreshInspiration">换一条</view>
    </view>
    <view wx:if="{{inspirationLoading}}" class="inspiration-loading">灵感整理中...</view>
    <view wx:elif="{{inspirationError}}" class="inspiration-error">{{inspirationError}}</view>
    <view wx:else class="inspiration-content">
      <view class="inspiration-block">
        <text class="inspiration-label">历史上的今天</text>
        <text class="inspiration-text">{{inspirationFact || '今天先写下一条记录，稍后再来看看灵感。'}}</text>
      </view>
      <view class="inspiration-block">
        <text class="inspiration-label">你的往年今日</text>
        <view wx:if="{{inspirationMemory}}">
          <text class="inspiration-text">{{inspirationMemory.year}} · {{inspirationMemory.content}}</text>
        </view>
        <text wx:else class="inspiration-text">还没有找到往年今日记录，今天可以从一条小记录开始。</text>
      </view>
    </view>
  </view>

  <view class="input-section section-card">
    <view class="section-head">
      <text class="section-title">快速记录</text>
    </view>
    <view class="input-tools">
      <text class="date-label">记录日期</text>
      <picker mode="date" value="{{selectedRecordDate}}" bindchange="onRecordDateChange">
        <view class="date-picker-trigger">
          <text class="date-value">{{selectedRecordDate}}</text>
          <text class="date-arrow">▼</text>
        </view>
      </picker>
    </view>
    <view class="input-wrap">
      <textarea
        class="input-area"
        placeholder="写下今天的想法、待办、心情或临时灵感..."
        bindinput="inputContent"
        bindfocus="handleInputFocus"
        bindblur="handleInputBlur"
        value="{{inputValue}}"
        maxlength="-1"
      ></textarea>
      <view wx:if="{{showInputTip}}" class="input-tip">可使用手机键盘自带语音输入，更快记录内容</view>
    </view>
    <view wx:if="{{showVoiceEntry}}" class="voice-bar">
      <button class="voice-btn {{isRecording ? 'voice-btn-recording' : ''}}" bindtap="toggleVoiceInput">
        <text class="voice-btn-icon">{{isRecording ? '⏹' : '🎙️'}}</text>
        <text class="voice-btn-text">{{isRecording ? '结束录音' : '开始录音'}}</text>
      </button>
      <text class="voice-status">{{voiceStatus}}</text>
    </view>
    <button class="save-btn" bindtap="saveInput">
      <text class="save-btn-icon">💾</text>
      <text class="save-btn-text">保存记录</text>
    </button>
  </view>

  <view class="records-list section-card">
    <view class="section-head">
      <view>
        <text class="section-title">最近记录</text>
        <text class="section-desc">{{recentRangeText}}</text>
      </view>
      <text class="records-count">{{recentRecordCount}} 条</text>
    </view>
    <scroll-view class="records-scroll" scroll-y enhanced show-scrollbar="false">
      <view wx:if="{{records.length > 0}}">
        <view class="record-item" wx:for="{{records}}" wx:key="_id">
          <view wx:if="{{item.recordType === 'audio'}}" class="record-item-content">
            <view class="audio-record-row">
              <view class="audio-record-main">
                <text class="audio-record-title">语音记录</text>
                <text class="audio-record-desc">{{item.audioDurationText || '时长未知'}}</text>
              </view>
              <view class="record-actions">
                <view
                  class="audio-play-btn {{playingRecordId === item._id ? 'audio-play-btn-active' : ''}}"
                  data-id="{{item._id}}"
                  data-fileid="{{item.audioFileID}}"
                  bindtap="playAudio"
                >{{playingRecordId === item._id ? '⏸' : '▶'}}</view>
                <view class="edit-btn" data-id="{{item._id}}" bindtap="editRecord">
                  <text class="edit-btn-icon">✏️</text>
                </view>
                <view class="delete-btn" data-id="{{item._id}}" bindtap="deleteRecord">
                  <text class="delete-btn-icon">×</text>
                </view>
              </view>
            </view>
            <text class="audio-record-note">{{item.transcriptText || item.content}}</text>
            <text class="record-item-time">{{item.createTime}}</text>
          </view>
          <view wx:else class="record-item-content">
            <view class="record-text-row">
              <text class="record-item-text">{{item.content}}</text>
              <view class="record-actions">
                <view class="edit-btn" data-id="{{item._id}}" bindtap="editRecord">
                  <text class="edit-btn-icon">✏️</text>
                </view>
                <view class="delete-btn" data-id="{{item._id}}" bindtap="deleteRecord">
                  <text class="delete-btn-icon">×</text>
                </view>
              </view>
            </view>
            <text class="record-item-time">{{item.createTime}}</text>
          </view>
        </view>
      </view>
      <view wx:else class="empty-state">
        <text class="empty-icon">📝</text>
        <text class="empty-title">近两周还没有记录</text>
        <text class="empty-desc">可以先打字记录下今天的想法、待办、心情或临时灵感。</text>
      </view>
    </scroll-view>
  </view>
</view>
