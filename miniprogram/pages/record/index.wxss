/* record/index.wxss */
.container {
  padding: 20rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.input-section {
  background-color: white;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.input-area {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  font-size: 24rpx;
  margin-bottom: 20rpx;
  resize: none;
}

.save-btn {
  width: 100%;
  height: 80rpx;
  border-radius: 40rpx;
  background-color: #07c160;
  color: white;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.records-list {
  background-color: white;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.list-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.record-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.record-item:last-child {
  border-bottom: none;
}

.record-item-content {
  display: flex;
  flex-direction: column;
}

.record-item-text {
  font-size: 24rpx;
  color: #333;
  margin-bottom: 10rpx;
  line-height: 1.5;
}

.record-item-time {
  font-size: 20rpx;
  color: #999;
  align-self: flex-end;
}

.summary-section {
  display: flex;
  justify-content: space-around;
}

.summary-btn {
  width: 300rpx;
  height: 80rpx;
  border-radius: 40rpx;
  background-color: #07c160;
  color: white;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

@keyframes pulse {
  0% {
    transform: scale(1);
    opacity: 1;
  }
  50% {
    transform: scale(1.1);
    opacity: 0.8;
  }
  100% {
    transform: scale(1);
    opacity: 1;
  }
}

/* 麦克风图标样式 */
.microphone-icon {
  width: 60rpx;
  height: 60rpx;
  position: relative;
}

.microphone-icon::before {
  content: '';
  position: absolute;
  width: 30rpx;
  height: 40rpx;
  background-color: white;
  border-radius: 15rpx 15rpx 0 0;
  top: 0;
  left: 15rpx;
}

.microphone-icon::after {
  content: '';
  position: absolute;
  width: 40rpx;
  height: 20rpx;
  background-color: white;
  border-radius: 20rpx;
  bottom: 0;
  left: 10rpx;
}
