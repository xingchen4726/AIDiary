.container {
  width: 100%;
  min-height: 100vh;
  padding: 34rpx 26rpx 120rpx;
  background: linear-gradient(180deg, #fbf8f2 0%, #f7f2ff 46%, #f2f6ff 100%);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: stretch;
}

.header {
  width: 100%;
  margin-bottom: 26rpx;
}

.title {
  display: block;
  font-size: 52rpx;
  font-weight: 700;
  color: #2b2434;
  line-height: 1.2;
  letter-spacing: 1rpx;
}

.subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #7d748b;
  line-height: 1.6;
}

.section-card {
  width: 100%;
  box-sizing: border-box;
  padding: 28rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(255, 255, 255, 0.7);
  box-shadow: 0 18rpx 44rpx rgba(60, 46, 90, 0.08);
  margin-bottom: 24rpx;
}

.section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 22rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #312a3d;
}

.section-tag {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #f3ecff;
  color: #6b5f86;
  font-size: 22rpx;
}

.summary-buttons {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.summary-btn {
  width: 100%;
  margin: 0;
  padding: 32rpx;
  border: none;
  border-radius: 26rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 12rpx;
  box-sizing: border-box;
  box-shadow: 0 16rpx 30rpx rgba(99, 87, 188, 0.22);
}

.summary-btn::after {
  border: none;
}

.summary-btn-daily {
  background: linear-gradient(140deg, #6f63ff 0%, #8e74ff 55%, #b08cff 100%);
  color: #ffffff;
}

.summary-btn-weekly {
  background: linear-gradient(140deg, #5d78ff 0%, #6d7eff 55%, #8ea0ff 100%);
  color: #ffffff;
}

.summary-btn-icon {
  font-size: 44rpx;
}

.summary-btn-text {
  font-size: 32rpx;
  font-weight: 600;
}

.summary-btn-desc {
  font-size: 22rpx;
  opacity: 0.9;
}

.records-count {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #f3ecff;
  color: #6b5f86;
  font-size: 22rpx;
}

.summary-scroll {
  max-height: 720rpx;
}

.summary-item {
  box-sizing: border-box;
  padding: 24rpx;
  border-radius: 20rpx;
  background: linear-gradient(160deg, #ffffff 0%, #fdfaff 100%);
  margin-bottom: 16rpx;
  border: 1rpx solid #efe5ff;
}

.summary-item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.summary-item-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #5f48a3;
}

.summary-item-date {
  font-size: 20rpx;
  color: #a297b4;
}

.summary-item-content {
  font-size: 24rpx;
  color: #574d67;
  line-height: 1.68;
  margin-bottom: 16rpx;
  word-break: break-word;
  writing-mode: horizontal-tb;
}

.summary-item-footer {
  display: flex;
  justify-content: flex-end;
}

.copy-btn {
  margin: 0;
  padding: 8rpx 18rpx;
  border: 1rpx solid #ece3ff;
  border-radius: 999rpx;
  background: #f6f1ff;
  color: #8575a7;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.copy-btn::after {
  border: none;
}

.copy-btn-icon {
  font-size: 20rpx;
}

.empty-state {
  padding: 70rpx 24rpx 60rpx;
  text-align: center;
}

.empty-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #4b3f61;
}

.empty-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #9a8faf;
  line-height: 1.7;
}
