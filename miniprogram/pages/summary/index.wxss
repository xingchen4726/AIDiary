.container {
  min-height: 100vh;
  padding: 32rpx 24rpx 120rpx;
  background: linear-gradient(180deg, #f4f8ff 0%, #f6f7fb 42%, #edf2ff 100%);
  box-sizing: border-box;
}

.header {
  margin-bottom: 28rpx;
}

.title {
  display: block;
  font-size: 52rpx;
  font-weight: 700;
  color: #1f2937;
  line-height: 1.2;
}

.subtitle {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #667085;
  line-height: 1.6;
}

.section-card {
  padding: 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 18rpx 40rpx rgba(15, 23, 42, 0.06);
  margin-bottom: 24rpx;
}

.section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
}

.section-tag {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #eef2ff;
  color: #4f46e5;
  font-size: 22rpx;
}

.summary-buttons {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.summary-btn {
  width: 100%;
  padding: 32rpx;
  border: none;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 12rpx;
  box-shadow: 0 16rpx 30rpx rgba(79, 124, 255, 0.15);
}

.summary-btn::after {
  border: none;
}

.summary-btn-daily {
  background: linear-gradient(135deg, #14b8a6 0%, #0ea5e9 100%);
  color: #ffffff;
}

.summary-btn-weekly {
  background: linear-gradient(135deg, #4f7cff 0%, #6d5dfc 100%);
  color: #ffffff;
}

.summary-btn-icon {
  font-size: 48rpx;
}

.summary-btn-text {
  font-size: 32rpx;
  font-weight: 600;
}

.summary-btn-desc {
  font-size: 22rpx;
  opacity: 0.9;
}

.records-count {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #f2f4f7;
  color: #475467;
  font-size: 22rpx;
}

.summary-scroll {
  max-height: 720rpx;
}

.summary-item {
  padding: 24rpx;
  border-radius: 20rpx;
  background: #f8faff;
  margin-bottom: 16rpx;
  border: 1rpx solid #e0e7ff;
}

.summary-item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.summary-item-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #1f2937;
}

.summary-item-date {
  font-size: 20rpx;
  color: #98a2b3;
}

.summary-item-content {
  font-size: 24rpx;
  color: #475467;
  line-height: 1.7;
  margin-bottom: 16rpx;
  word-break: break-word;
}

.summary-item-footer {
  display: flex;
  justify-content: flex-end;
}

.copy-btn {
  margin: 0;
  padding: 8rpx 16rpx;
  border: 1rpx solid #d1d5db;
  border-radius: 12rpx;
  background: #ffffff;
  color: #475467;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.copy-btn::after {
  border: none;
}

.copy-btn-icon {
  font-size: 20rpx;
}

.empty-state {
  padding: 70rpx 24rpx 60rpx;
  text-align: center;
}

.empty-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #344054;
}

.empty-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #98a2b3;
  line-height: 1.7;
}